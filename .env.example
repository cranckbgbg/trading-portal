# =============================================
# DATABASE — Neon PostgreSQL
# Get from: https://neon.tech → Your project → Connection string
# =============================================
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# =============================================
# NEXTAUTH
# NEXTAUTH_SECRET: generate with → openssl rand -base64 32
# NEXTAUTH_URL: your Vercel production URL
# =============================================
NEXTAUTH_URL="https://your-project.vercel.app"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# =============================================
# EMAIL — Resend SMTP
# Get API key from: https://resend.com → API Keys
# EMAIL_FROM must match a verified domain in Resend
# For testing: use onboarding@resend.dev as FROM (no domain needed)
# =============================================
EMAIL_SERVER="smtps://resend:re_YOUR_API_KEY@smtp.resend.com:465"
EMAIL_FROM="noreply@yourdomain.com"

# =============================================
# STRIPE — Payments
# Get from: https://dashboard.stripe.com → Developers → API keys
# Create products in Stripe → copy price IDs
# =============================================
STRIPE_SECRET_KEY="sk_live_replace"
STRIPE_WEBHOOK_SECRET="whsec_replace"
STRIPE_PRICE_MONTHLY="price_replace_monthly"
STRIPE_PRICE_YEARLY="price_replace_yearly"

# =============================================
# N8N — Automated news publishing (optional)
# Used to authenticate incoming n8n webhook requests
# Set any random secret string
# =============================================
N8N_WEBHOOK_API_KEY="replace-with-a-private-api-key"
