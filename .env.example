# =============================================
# xrent.bg — environment variables
# Copy to .env and fill in. Never commit real secrets.
# =============================================

# ---------------------------------------------
# DATABASE — PostgreSQL (Phase 0/1)
# Must be a Postgres instance where the btree_gist extension can be created
# (needed for the no-double-booking exclusion constraint, B-01).
# ---------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/xrent?schema=public"

# ---------------------------------------------
# NEXTAUTH (Phase 1)
# NEXTAUTH_SECRET: generate with → openssl rand -base64 32
# ---------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ---------------------------------------------
# SEED (optional) — initial admin credentials
# ---------------------------------------------
SEED_ADMIN_EMAIL="admin@xrent.bg"
SEED_ADMIN_PASSWORD="Admin1234"

# ---------------------------------------------
# EMAIL — transactional mail (Phase 6, not used yet)
# ---------------------------------------------
EMAIL_SERVER="smtps://user:pass@smtp.example.com:465"
EMAIL_FROM="noreply@xrent.bg"

# ---------------------------------------------
# PRIVATE STORAGE — customer documents (Phase 6, not used yet)
# S3-compatible private bucket; documents are never served via public URLs.
# ---------------------------------------------
STORAGE_ENDPOINT=""
STORAGE_BUCKET="xrent-documents"
STORAGE_KEY=""
STORAGE_SECRET=""

# ---------------------------------------------
# STRIPE — payments (Phase 4, not used yet)
# ---------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
